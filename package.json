{
	"name": "can-log-viewer",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types --check && vite build",
		"wasm:build": "cd wasm && zig build",
		"wasm:build:release": "cd wasm && zig build -Doptimize=ReleaseSmall",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"gen": "wrangler types",
		"test:unit": "vitest",
		"test": "bun run test:unit -- --run"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/geist": "5.2.8",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^0.577.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"remixicon-svelte": "0.0.5",
		"shadcn-svelte": "1.2.7",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"wrangler": "^4.81.0"
	},
	"dependencies": {
		"zod": "4.3.6"
	}
}
